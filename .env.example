# Clikarage - public Vite configuration
# Copy to .env for local development. Never add service_role or provider secrets.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional public booking organization.
VITE_DEMO_GARAGE_SLUG=garage-central-lyon

# Prepared capabilities remain off until their migrations have been validated
# and applied in the target environment. Presentation accounts enable local
# simulations without querying these Supabase tables.
VITE_ENABLE_CENTERS=false
VITE_ENABLE_WORKSHOP_TIMELINE=false
VITE_ENABLE_RECOMMENDATIONS=false
VITE_ENABLE_ATTACHMENTS=false
VITE_ENABLE_NOTIFICATIONS=false
VITE_ENABLE_DELIVERY_REPORTS=false
VITE_ENABLE_MAINTENANCE_REMINDERS=false
VITE_ENABLE_NETWORK_DASHBOARD=false
VITE_ENABLE_INTEGRATIONS=false

# Legal V2 is staged and non-effective until human legal approval. These flags
# are intentionally independent so documents can be reviewed without enabling
# acceptance, DPA signature or any external service.
VITE_LEGAL_DOCS_V2_ENABLED=false
VITE_LEGAL_ACCEPTANCE_V2_ENABLED=false
VITE_DPA_SELF_SERVICE_ENABLED=false
VITE_SUBPROCESSOR_REGISTRY_ENABLED=false
VITE_VERCEL_ANALYTICS_ENABLED=false
VITE_STRIPE_ENABLED=false
VITE_AI_FEATURES_ENABLED=false
VITE_DOCUMENT_STORAGE_ENABLED=false
VITE_TRANSACTIONAL_EMAIL_ENABLED=false

# Optional white-label build identifier. Empty keeps the Clikarage brand.
VITE_BRAND=
