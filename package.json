{
  "name": "garageflow-c",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Clikarage — SaaS/PWA pour garages indépendants (Pro back-office + Client mobile-first).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4174",
